# .env.example

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=database_name

# API Keys
API_KEY=your_api_key_here

# Other Environment Variables
DEBUG=True
SECRET_KEY=your_secret_key_here

# Application Configurations
APP_PORT=5000
APP_LOG_LEVEL=info
